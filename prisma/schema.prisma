generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User 모델
model User {
  // 기본 정보
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String   @unique
  height      Float?  
  weight      Float?  

  // 3대 정보
  squat       Int       @default(0)
  bench       Int       @default(0)
  deadlift    Int       @default(0)

  // Relationship
  posts       Post[]
  votes       Vote[]
  comments    Comment[]
  rankingLogs RankingLog[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 2. 게시글 모델
model Post {
  id        Int     @id @default(autoincrement())
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])


  category  PostCategory
  title     String
  content   String  @db.Text
  imageUrl  String?   // 오운완 게시글에선 필수

  votes     Vote[]
  comments  Comment[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum PostCategory {
  DEBATE
  WORKOUT
}

// 3. 투표 모델
model Vote {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  postId    Int
  post      Post    @relation(fields: [postId], references: [id])

  isPros    Boolean

  createdAt DateTime  @default(now())

  // 정책: 유저당 1회 투표 제한
  @@unique([userId, postId])
}

// 4. 댓글 모델
model Comment {
  id        Int     @id @default(autoincrement())
  authorId  Int     
  author    User    @relation(fields: [authorId], references: [id])
  postId    Int     
  post      Post    @relation(fields: [postId], references: [id])

  content   String  @db.Text
  likes     Int     @default(0)

  createdAt DateTime @default(now())
}

// 5. 랭킹 로그 모델
model RankingLog {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  
  weekNumber  Int   
  totalSBD    Int
  diffSBD     Int   @default(0)

  createdAt DateTime @default(now())
  
}